# Obrigatório: URL base da API Django (sem barra no final).
# Local: suba o backend com python manage.py runserver
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api

# Render — copie para Environment do Web Service (sem barra no final):
# NEXT_PUBLIC_API_URL=https://monitoramento-backend-api.onrender.com/api
# (troque o host se o nome do servico da API for outro)
#
# No backend Django (DEBUG=false), defina também:
# CORS_ALLOWED_ORIGINS=https://SEU-FRONT.onrender.com
# CSRF_TRUSTED_ORIGINS=https://SEU-FRONT.onrender.com
